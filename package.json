{
  "name": "@repo/package-template",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript monorepo template with vitest, turbo, husky, and changesets",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "clean": "turbo clean",
    "prepare": "husky install",
    "release": "changesets version && pnpm install --no-frozen-lockfile && git add .",
    "publish": "turbo build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript-eslint": "^8.64.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "changesets": {
    "baseBranch": "main",
    "changelog": false,
    "commit": false,
    "fixed": [],
    "linked": [],
    "access": "restricted"
  }
}
