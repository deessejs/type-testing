{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".next/**"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "cache": true
    },
    "lint:publint": {
      "cache": true,
      "inputs": [
        "packages/type-testing/package.json",
        "packages/type-testing/dist/**"
      ]
    },
    "lint:attw": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": [
        "packages/type-testing/package.json",
        "packages/type-testing/dist/**"
      ]
    },
    "lint:sherif": {
      "cache": true,
      "inputs": [
        "**/package.json",
        "pnpm-lock.yaml",
        "pnpm-workspace.yaml"
      ]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": true
    },
    "test:coverage": {
      "dependsOn": ["^test:coverage"],
      "cache": true
    },
    "clean": {
      "cache": false
    }
  }
}
